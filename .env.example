# Переменные окружения (не коммитить в репозиторий)

# API
# VITE_API_URL=https://api.fastfingers.local

# AI Provider
# VITE_AI_PROVIDER=yandex
# VITE_AI_API_KEY=your-api-key-here

# Sentry (отслеживание ошибок)
# Получите DSN на https://sentry.io
# VITE_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# Supabase (база данных и аутентификация)
# 1. Создайте проект на https://supabase.com
# 2. Выполните SQL миграцию из supabase/migrations/001_initial_schema.sql
# 3. Скопируйте URL и анонимный ключ из настроек проекта
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
