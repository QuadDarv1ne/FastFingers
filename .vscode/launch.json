{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Dev + Tests",
      "configurations": ["Dev Server", "Vitest Watch"],
      "presentation": {
        "hidden": false,
        "group": "development",
        "order": 1
      }
    }
  ],
  "configurations": [
    {
      "name": "Dev Server",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "npm: dev",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    },
    {
      "name": "Launch Chrome (no task)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/src"
    },
    {
      "name": "Vitest Watch",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run test",
      "name": "Vitest Watch"
    },
    {
      "name": "Vitest Current File",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test", "--", "${relativeFile}", "--run"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Vitest Debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test", "--", "--run", "--no-threads"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "E2E Tests (Playwright)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "e2e"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "E2E Tests (headed)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "e2e:headed"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Build",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run build",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Preview Production Build",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4173",
      "preLaunchTask": "npm: preview",
      "webRoot": "${workspaceFolder}/dist"
    }
  ]
}
