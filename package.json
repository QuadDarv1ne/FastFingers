{
  "name": "fastfingers",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "author": "Dupley Maxim Igorevich",
  "license": "UNLICENSED",
  "description": "Proprietary software. All rights reserved to Dupley Maxim Igorevich.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && node build.mjs",
    "build:fast": "node build.mjs",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:fast": "vitest run --pool=threads",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "build:all": "npm run build && npm run build:mobile && npm run build:desktop",
    "build:mobile": "npx cap sync",
    "build:android": "npm run build && npx cap sync android && npx cap open android",
    "build:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "build:desktop": "npm run build && npm run tauri:build",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap run android",
    "cap:ios": "npx cap run ios",
    "lhci": "lhci autorun",
    "lhci:check": "lhci assert",
    "lhci:collect": "lhci collect",
    "lhci:upload": "lhci upload",
    "server:install": "cd server && npm install",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "server:start": "cd server && npm start",
    "dev:full": "concurrently \"npm run server:dev\" \"npm run dev\""
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sentry/react": "^10.39.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-virtual": "^3.13.21",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.40.0",
    "i18next": "^25.8.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.5.2",
    "axe-playwright": "^2.2.2",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.16",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
