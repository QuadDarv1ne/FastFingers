# Tauri gitignore

# Build outputs
/target
**/target/**

# Node modules (keep root node_modules)
node_modules/

# Build artifacts
*.o
*.so
*.dylib
*.dll
*.exe
*.app
*.dmg
*.deb
*.rpm
*.msi
*.pkg

# Development
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Signing
*.keystore
*.jks
